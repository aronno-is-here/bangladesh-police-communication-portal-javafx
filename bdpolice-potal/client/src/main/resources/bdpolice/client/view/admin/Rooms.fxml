<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" spacing="12" padding="16">
  <children>
    <Label text="Chat Room Management" styleClass="pageTitle" />
    <TextField promptText="Search rooms by name or description..." />
    <TableView>
      <columns>
        <TableColumn text="Name" prefWidth="240" />
        <TableColumn text="Status" prefWidth="120" />
        <TableColumn text="Participants" prefWidth="120" />
        <TableColumn text="Last Activity" prefWidth="160" />
        <TableColumn text="Actions" prefWidth="220" />
      </columns>
    </TableView>
  </children>
</VBox>
