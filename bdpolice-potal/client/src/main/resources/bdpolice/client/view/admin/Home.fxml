<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" spacing="16" padding="16">
  <children>
    <Label text="Admin Dashboard" styleClass="pageTitle" />
    <HBox spacing="12">
      <children>
        <TitledPane text="Active Rooms" expanded="true">
          <content>
            <VBox spacing="8" padding="10">
              <children>
                <Label text="12" styleClass="statValue" />
                <Label text="+2 from yesterday" styleClass="muted" />
              </children>
            </VBox>
          </content>
        </TitledPane>
        <TitledPane text="Total Officers" expanded="true">
          <content>
            <VBox spacing="8" padding="10">
              <children>
                <Label text="45" styleClass="statValue" />
                <Label text="3 online now" styleClass="muted" />
              </children>
            </VBox>
          </content>
        </TitledPane>
        <TitledPane text="Pending Reports" expanded="true">
          <content>
            <VBox spacing="8" padding="10">
              <children>
                <Label text="8" styleClass="statValue" />
                <Label text="Needs attention" styleClass="muted" />
              </children>
            </VBox>
          </content>
        </TitledPane>
      </children>
    </HBox>

    <TitledPane text="Create New Chat Room" expanded="true">
      <content>
        <HBox spacing="10" padding="10">
          <children>
            <TextField promptText="Enter room name (e.g., Operation Sunrise)" HBox.hgrow="ALWAYS" />
            <Button text="Create Room" styleClass="primaryButton" />
            <Button text="Add Officers" />
          </children>
        </HBox>
      </content>
    </TitledPane>
  </children>
</VBox>
